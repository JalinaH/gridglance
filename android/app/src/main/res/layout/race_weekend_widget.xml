<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Top: race info (left) + track layout (right) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Left: race details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Header row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="3dp"
                    android:background="@drawable/widget_accent"
                    android:text="" />

                <TextView
                    android:id="@+id/widget_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="sans-serif-condensed"
                    android:includeFontPadding="false"
                    android:text="Race Weekend"
                    android:textAllCaps="true"
                    android:textColor="#F7F8FA"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="" />

                <TextView
                    android:id="@+id/race_round"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/widget_round_badge"
                    android:includeFontPadding="false"
                    android:paddingLeft="6dp"
                    android:paddingRight="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:text="R1"
                    android:textColor="#E10600"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Race name -->
            <TextView
                android:id="@+id/race_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-condensed"
                android:includeFontPadding="false"
                android:maxLines="2"
                android:text="Australian Grand Prix"
                android:textColor="#F7F8FA"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Location -->
            <TextView
                android:id="@+id/race_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="Melbourne, Australia"
                android:textColor="#9EA7B5"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Right: track layout image -->
        <ImageView
            android:id="@+id/track_image"
            android:layout_width="80dp"
            android:layout_height="60dp"
            android:layout_marginStart="12dp"
            android:alpha="0.6"
            android:scaleType="fitCenter" />
    </LinearLayout>

    <!-- Countdown row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/widget_row_highlight"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="7dp">

        <TextView
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/widget_timeline_dot_active"
            android:text="" />

        <TextView
            android:id="@+id/next_session_countdown"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="Qualifying in 2d 4h"
            android:textColor="#F7F8FA"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Session timeline -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/session_1_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">

            <TextView
                android:id="@+id/session_1_dot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/widget_timeline_dot"
                android:text="" />

            <TextView
                android:id="@+id/session_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="FP1 · Fri 14 Mar · 11:30 AM"
                android:textColor="#9EA7B5"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/session_2_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">

            <TextView
                android:id="@+id/session_2_dot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/widget_timeline_dot"
                android:text="" />

            <TextView
                android:id="@+id/session_2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="FP2 · Fri 14 Mar · 3:00 PM"
                android:textColor="#9EA7B5"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/session_3_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">

            <TextView
                android:id="@+id/session_3_dot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/widget_timeline_dot"
                android:text="" />

            <TextView
                android:id="@+id/session_3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="FP3 · Sat 15 Mar · 12:30 PM"
                android:textColor="#9EA7B5"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/session_4_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">

            <TextView
                android:id="@+id/session_4_dot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/widget_timeline_dot"
                android:text="" />

            <TextView
                android:id="@+id/session_4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="QUAL · Sat 15 Mar · 4:00 PM"
                android:textColor="#9EA7B5"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/session_5_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">

            <TextView
                android:id="@+id/session_5_dot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/widget_timeline_dot"
                android:text="" />

            <TextView
                android:id="@+id/session_5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="RACE · Sun 16 Mar · 3:00 PM"
                android:textColor="#9EA7B5"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/session_6_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/session_6_dot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/widget_timeline_dot"
                android:text="" />

            <TextView
                android:id="@+id/session_6"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="#9EA7B5"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/session_7_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/session_7_dot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/widget_timeline_dot"
                android:text="" />

            <TextView
                android:id="@+id/session_7"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="#9EA7B5"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
