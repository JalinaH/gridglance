<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="36dp"
            android:layout_height="3dp"
            android:background="@drawable/widget_accent"
            android:text="" />

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="sans-serif-condensed"
            android:includeFontPadding="false"
            android:text="Driver"
            android:textAllCaps="true"
            android:textColor="#F7F8FA"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="" />

        <TextView
            android:id="@+id/widget_season"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_pill"
            android:includeFontPadding="false"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:text="----"
            android:textColor="#B8C0CC"
            android:textSize="9sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Podium area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="bottom"
        android:orientation="horizontal">

        <!-- 2nd place -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/driver_two_photo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/widget_driver_photo_large"
                android:contentDescription="P2 driver"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/driver_two_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-condensed"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="NORRIS"
                android:textColor="#DCE1EA"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/driver_two_pts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:includeFontPadding="false"
                android:text="374 pts"
                android:textColor="#9EA7B5"
                android:textSize="8sp" />

            <!-- P2 podium block -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginStart="3dp"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="3dp"
                android:background="@drawable/widget_podium_silver"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="2"
                android:textColor="#9EA7B5"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 1st place -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/driver_one_photo"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/widget_driver_photo_gold"
                android:contentDescription="P1 driver"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/driver_one_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-condensed"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="VERSTAPPEN"
                android:textColor="#F7F8FA"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/driver_one_pts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:includeFontPadding="false"
                android:text="437 pts"
                android:textColor="#DCE1EA"
                android:textSize="8sp" />

            <!-- P1 podium block -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginStart="3dp"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="3dp"
                android:background="@drawable/widget_podium_gold"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="1"
                android:textColor="#E10600"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 3rd place -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/driver_three_photo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/widget_driver_photo_large"
                android:contentDescription="P3 driver"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/driver_three_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-condensed"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="LECLERC"
                android:textColor="#DCE1EA"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/driver_three_pts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:includeFontPadding="false"
                android:text="356 pts"
                android:textColor="#9EA7B5"
                android:textSize="8sp" />

            <!-- P3 podium block -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="26dp"
                android:layout_marginStart="3dp"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="3dp"
                android:background="@drawable/widget_podium_bronze"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="3"
                android:textColor="#CD7F32"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
