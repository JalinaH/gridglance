<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical">

    <!-- Top half: car image with team color overlay -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ImageView
            android:id="@+id/team_car"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/widget_team_car"
            android:contentDescription="Team car"
            android:padding="6dp"
            android:scaleType="fitCenter" />

        <!-- Team name overlay on car -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/team_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="sans-serif-condensed"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:shadowColor="#CC000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="4"
                android:text="Ferrari"
                android:textAllCaps="true"
                android:textColor="#F7F8FA"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_season"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_pill"
                android:includeFontPadding="false"
                android:paddingLeft="6dp"
                android:paddingRight="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="----"
                android:textColor="#B8C0CC"
                android:textSize="8sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <!-- Bottom half: team details with team-colored accent -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Team color accent bar -->
        <TextView
            android:id="@+id/team_color_bar"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@drawable/widget_accent_stripe"
            android:text="" />

        <!-- Details area -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <!-- Driver 1 row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Driver 1 number badge -->
                <TextView
                    android:id="@+id/driver1_number"
                    android:layout_width="26dp"
                    android:layout_height="22dp"
                    android:background="@drawable/widget_driver_number_bg"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="16"
                    android:textColor="#F7F8FA"
                    android:textSize="12sp"
                    android:textStyle="bold|italic" />

                <TextView
                    android:id="@+id/driver1_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-condensed"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="LECLERC"
                    android:textColor="#F7F8FA"
                    android:textSize="12sp"
                    android:textStyle="bold|italic" />

                <TextView
                    android:id="@+id/driver1_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="LEC"
                    android:textColor="#9EA7B5"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Driver 2 row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Driver 2 number badge -->
                <TextView
                    android:id="@+id/driver2_number"
                    android:layout_width="26dp"
                    android:layout_height="22dp"
                    android:background="@drawable/widget_driver_number_bg"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="55"
                    android:textColor="#F7F8FA"
                    android:textSize="12sp"
                    android:textStyle="bold|italic" />

                <TextView
                    android:id="@+id/driver2_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-condensed"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="HAMILTON"
                    android:textColor="#F7F8FA"
                    android:textSize="12sp"
                    android:textStyle="bold|italic" />

                <TextView
                    android:id="@+id/driver2_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="HAM"
                    android:textColor="#9EA7B5"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Position stat -->
                <LinearLayout
                    android:id="@+id/pos_box"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/widget_driver_number_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="5dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-condensed"
                        android:includeFontPadding="false"
                        android:text="P"
                        android:textColor="#9EA7B5"
                        android:textSize="11sp"
                        android:textStyle="bold|italic" />

                    <TextView
                        android:id="@+id/team_position"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-condensed"
                        android:includeFontPadding="false"
                        android:text="--"
                        android:textColor="#F7F8FA"
                        android:textSize="16sp"
                        android:textStyle="bold|italic" />
                </LinearLayout>

                <TextView
                    android:layout_width="6dp"
                    android:layout_height="0dp"
                    android:text="" />

                <!-- Points stat -->
                <LinearLayout
                    android:id="@+id/pts_box"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:background="@drawable/widget_driver_number_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="5dp">

                    <TextView
                        android:id="@+id/team_points"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-condensed"
                        android:includeFontPadding="false"
                        android:text="--"
                        android:textColor="#F7F8FA"
                        android:textSize="16sp"
                        android:textStyle="bold|italic" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:fontFamily="sans-serif-condensed"
                        android:includeFontPadding="false"
                        android:text="PTS"
                        android:textColor="#9EA7B5"
                        android:textSize="9sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
